{
  "name": "site-amaral",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.9.0 <25"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:client": "vite --port 5174",
    "dev:server": "cross-env NODE_ENV=development tsx watch server/src/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "tsc -b tsconfig.app.json tsconfig.node.json && vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "cross-env NODE_ENV=production node server/dist/index.js",
    "db:seed-admin": "cross-env NODE_ENV=development tsx server/scripts/seed-admin.ts",
    "db:init": "echo 'Por favor, execute o arquivo server/sql/schema.sql manualmente no seu MySQL Client (ex: Workbench, HeidiSQL ou terminal: mysql -u root -p < server/sql/schema.sql)'"
  },
  "dependencies": {
    "@tiptap/extension-placeholder": "^3.20.2",
    "@tiptap/react": "^3.20.2",
    "@tiptap/starter-kit": "^3.20.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.577.0",
    "mysql2": "^3.19.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "tsx": "^4.21.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10"
  }
}
