PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://seu-dominio-ou-app.railway.app

# OBRIGATÓRIO: Gere um valor real com: openssl rand -hex 32
JWT_SECRET=EXEMPLO_SUBSTITUA_POR_VALOR_REAL_ALEATORIO_64_CARACTERES
JWT_EXPIRES_IN=7d

DB_HOST=railway_mysql_host
DB_PORT=3306
DB_USER=railway_mysql_user
DB_PASSWORD=railway_mysql_password
DB_NAME=railway_mysql_database

ADMIN_SEED_NAME=Administrador
ADMIN_SEED_EMAIL=admin@seudominio.com.br

# OBRIGATÓRIO: Use uma senha forte e única
ADMIN_SEED_PASSWORD=EXEMPLO_SUBSTITUA_POR_SENHA_FORTE_REAL
